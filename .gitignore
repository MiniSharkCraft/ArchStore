# ─── Build artifacts ───────────────────────────────────────────────────────────
build/bin/
build/darwin/
build/windows/
build/linux/
build/*.AppDir/
frontend/dist/

# ─── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
cloudflare/worker/node_modules/
installer/node_modules/

# ─── Installer build output ────────────────────────────────────────────────────
installer/dist/

# ─── Go ────────────────────────────────────────────────────────────────────────
*.exe
*.test
*.out
vendor/

# ─── Wails generated bindings (auto-regenerated bởi `wails dev` hoặc `wails build`)
# Uncomment nếu muốn commit để CI không cần wails toolchain:
# frontend/wailsjs/

# ─── Cloudflare / Wrangler ─────────────────────────────────────────────────────
# wrangler.toml chứa database_id thật và Worker URL cá nhân — dùng wrangler.toml.example
cloudflare/worker/wrangler.toml
# Wrangler local dev state — chứa account_id và email
cloudflare/worker/.wrangler/
.wrangler/

# ─── Môi trường & Secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets.json
secrets.toml
*.pem
*.key
*.p12
*.pfx

# ─── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.fleet/

# ─── Claude Code (local AI assistant state) ────────────────────────────────────
.claude/

# ─── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Log ───────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Temporary ─────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
