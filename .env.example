# ─────────────────────────────────────────────────────────────────────────────
# ArchStore — Environment Variables
# Copy file này thành .env và điền giá trị thật (không commit .env)
# ─────────────────────────────────────────────────────────────────────────────

# URL của Cloudflare Worker bạn tự deploy
# (xem cloudflare/worker/wrangler.toml.example để setup)
ARCHSTORE_CF_WORKER_URL=https://YOUR_WORKER_NAME.YOUR_SUBDOMAIN.workers.dev

# Shared secret giữa desktop app và Cloudflare Worker
# Phải khớp với giá trị đã set bằng: wrangler secret put ARCHSTORE_API_KEY
# Tạo key ngẫu nhiên: openssl rand -base64 48
ARCHSTORE_API_KEY=your-random-secret-key-here
